{
  "entities": {
    "Patient": {
      "title": "Patient",
      "description": "Patient information",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "mrn": { "type": "string" },
        "national_id": { "type": "string" },
        "first_name": { "type": "string" },
        "last_name": { "type": "string" },
        "date_of_birth": { "type": "string", "format": "date" },
        "gender": { "type": "string", "enum": ["MALE", "FEMALE"] },
        "phone_mobile": { "type": "string" }
      },
      "required": ["id", "mrn", "first_name", "last_name", "date_of_birth", "gender", "phone_mobile"]
    },
    "Encounter": {
      "title": "Encounter",
      "description": "Patient visit information",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "patient_id": { "type": "string" },
        "encounter_type": { "type": "string", "enum": ["OPD", "IPD", "ER"] },
        "status": { "type": "string", "enum": ["SCHEDULED", "CHECKED_IN", "IN_PROGRESS", "ON_HOLD", "CLOSED", "CANCELLED"] }
      },
      "required": ["id", "patient_id", "encounter_type", "status"]
    }
  },
  "firestore": {
    "/patients/{patientId}": {
      "schema": "Patient",
      "description": "Patient collection"
    },
    "/encounters/{encounterId}": {
      "schema": "Encounter",
      "description": "Encounter collection"
    }
  }
}
