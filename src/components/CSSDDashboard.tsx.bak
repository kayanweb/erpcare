import React, { useState } from "react";
import { 
  ShieldCheck, ArrowRightLeft, PackageCheck, Layers, LayoutDashboard, 
  Wind, Thermometer, ShieldAlert, BadgeCheck, Zap, History, Search, 
  PlayCircle, RefreshCcw, Droplets
} from "lucide-react";

export default function CSSDDashboard({ language }: { language: "ar" | "en" }) {
  const isAr = language === "ar";
  
  const [activeTab, setActiveTab] = useState("dashboard");
  
  const tabs = [
    { id: "dashboard", icon: LayoutDashboard, en: "Command Center", ar: "مركز القيادة" },
    { id: "decontamination", icon: Droplets, en: "Decontamination", ar: "التطهير والغسيل" },
    { id: "assembly", icon: Layers, en: "Assembly & Packing", ar: "التجميع والتغليف" },
    { id: "sterilization", icon: Wind, en: "Sterilization (Autoclaves)", ar: "التعقيم (الأوتوكلاف)" },
    { id: "dispatch", icon: ArrowRightLeft, en: "Dispatch / Distribution", ar: "التوزيع والإرسال" }
  ];

  const statCards = [
    { label: isAr ? "قيد المعالجة" : "In Processing", value: "24", icon: RefreshCcw, color: "text-amber-600", bg: "bg-amber-100" },
    { label: isAr ? "معقمة جاهزة" : "Sterile Ready", value: "115", icon: ShieldCheck, color: "text-emerald-600", bg: "bg-emerald-100" },
    { label: isAr ? "دورات الأوتوكلاف" : "Active Cycles", value: "3", icon: Wind, color: "text-indigo-600", bg: "bg-indigo-100" },
    { label: isAr ? "طلبات مستعجلة (العمليات)" : "Urgent OR Requests", value: "2", icon: Zap, color: "text-rose-600", bg: "bg-rose-100" }
  ];

  const decontaminationQueue = [
    { id: "TR-1029", origin: "OR Room 4", content: "Major General Surgery Set", status: "Washing", timeIn: "10:15 AM", priority: "High" },
    { id: "TR-1030", origin: "Ward B", content: "Dressing Sets (x5)", status: "Pending", timeIn: "10:45 AM", priority: "Normal" },
    { id: "TR-1031", origin: "ER", content: "Suture Tray", status: "Washing", timeIn: "11:00 AM", priority: "High" }
  ];

  const activeAutoclaves = [
    { id: "AC-01", type: "Steam", status: "Running", cyclePhase: "Sterilizing", temp: "134°C", pressure: "2.1 bar", timeRemaining: "15 min" },
    { id: "AC-02", type: "Steam", status: "Idle", cyclePhase: "-", temp: "22°C", pressure: "0 bar", timeRemaining: "-" },
    { id: "AC-03", type: "Plasma", status: "Running", cyclePhase: "Plasma Injection", temp: "50°C", pressure: "Vacuum", timeRemaining: "28 min" }
  ];

  return (
    <div className="flex flex-col h-full bg-slate-50" dir={isAr ? "rtl" : "ltr"}>
      <div className="bg-white border-b border-slate-200 px-6 py-4 shrink-0 shadow-sm z-10 flex items-center justify-between">
        <div className="flex items-center gap-3">
          <div className="w-10 h-10 bg-indigo-100 rounded-xl flex items-center justify-center text-indigo-600">
            <ShieldCheck size={20} />
          </div>
          <div>
            <h1 className="text-xl font-black text-slate-800 uppercase tracking-tight">
              {isAr ? "التعقيم المركزي (CSSD)" : "Central Sterile Services"}
            </h1>
            <p className="text-xs font-bold text-slate-500">
              {isAr ? "إدارة تعقيم وتتبع الأدوات الجراحية" : "Surgical Instrument Processing & Tracking"}
            </p>
          </div>
        </div>
      </div>

      <div className="flex flex-1 overflow-hidden">
        {/* Sidebar Tabs */}
        <div className="w-64 bg-white border-r border-slate-200 shrink-0 flex flex-col p-4 space-y-1">
          {tabs.map((tab) => {
            const isActive = activeTab === tab.id;
            return (
              <button
                key={tab.id}
                onClick={() => setActiveTab(tab.id)}
                className={`flex items-center gap-3 w-full px-4 py-3 rounded-xl text-sm font-bold transition-all duration-200 ${isActive ? "bg-indigo-50 text-indigo-700 shadow-sm ring-1 ring-indigo-200" : "text-slate-600 hover:bg-slate-100"}`}
              >
                <tab.icon size={18} className={isActive ? "text-indigo-600" : "text-slate-400"} />
                {isAr ? tab.ar : tab.en}
              </button>
            )
          })}
        </div>

        {/* Content Area */}
        <div className="flex-1 overflow-y-auto p-6 lg:p-8 space-y-8 custom-scrollbar">
          
          {activeTab === "dashboard" && (
            <>
              {/* Stats */}
              <div className="grid grid-cols-1 md:grid-cols-4 gap-6">
                {statCards.map((stat, i) => (
                  <div key={i} className="bg-white p-5 rounded-2xl border border-slate-200 shadow-sm flex items-center gap-4">
                    <div className={`w-12 h-12 rounded-xl flex items-center justify-center ${stat.bg} ${stat.color}`}>
                      <stat.icon size={24} />
                    </div>
                    <div>
                      <p className="text-xs font-bold text-slate-400 uppercase">{stat.label}</p>
                      <p className="text-2xl font-black text-slate-800">{stat.value}</p>
                    </div>
                  </div>
                ))}
              </div>

              <div className="grid grid-cols-1 lg:grid-cols-2 gap-8">
                {/* Active Autoclaves */}
                <div className="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden flex flex-col">
                  <div className="p-4 border-b border-slate-100 bg-slate-50 flex items-center justify-between">
                    <h3 className="font-extrabold text-slate-800 flex items-center gap-2">
                      <Wind size={16} className="text-indigo-600" />
                      {isAr ? "أجهزة الأوتوكلاف النشطة" : "Active Autoclaves"}
                    </h3>
                  </div>
                  <div className="p-4 space-y-4">
                    {activeAutoclaves.map(ac => (
                      <div key={ac.id} className="border border-slate-100 p-4 rounded-xl flex items-center justify-between hover:border-indigo-100 hover:shadow-md transition-all">
                        <div>
                          <div className="flex items-center gap-2">
                            <h4 className="font-bold text-slate-800">{ac.id}</h4>
                            <span className="text-[10px] font-black uppercase bg-slate-100 px-2 py-0.5 rounded-full text-slate-600">{ac.type}</span>
                            {ac.status === 'Running' ? (
                              <span className="text-[10px] font-black uppercase bg-emerald-100 px-2 py-0.5 rounded-full text-emerald-700 animate-pulse">{ac.status}</span>
                            ) : (
                              <span className="text-[10px] font-black uppercase bg-slate-100 px-2 py-0.5 rounded-full text-slate-500">{ac.status}</span>
                            )}
                          </div>
                          <p className="text-xs font-medium text-slate-500 mt-1">
                            Phase: <span className="text-indigo-600 font-bold">{ac.cyclePhase}</span> | Temp: {ac.temp} | Press: {ac.pressure}
                          </p>
                        </div>
                        <div className="text-right">
                          <p className="text-[10px] font-bold text-slate-400 uppercase">{isAr ? "الوقت المتبقي" : "Time Left"}</p>
                          <p className="font-black text-slate-800">{ac.timeRemaining}</p>
                        </div>
                      </div>
                    ))}
                  </div>
                </div>

                {/* Decontamination Queue */}
                <div className="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden flex flex-col">
                  <div className="p-4 border-b border-slate-100 bg-slate-50 flex items-center justify-between">
                    <h3 className="font-extrabold text-slate-800 flex items-center gap-2">
                      <Droplets size={16} className="text-blue-600" />
                      {isAr ? "طابور الغسيل والتطهير" : "Decontamination Queue"}
                    </h3>
                  </div>
                  <div className="overflow-x-auto">
                    <table className="w-full text-left border-collapse">
                      <thead>
                        <tr className="bg-slate-50/50 text-[10px] uppercase tracking-wider text-slate-500">
                          <th className="p-3 font-bold border-b border-slate-100">Tray ID</th>
                          <th className="p-3 font-bold border-b border-slate-100">Origin</th>
                          <th className="p-3 font-bold border-b border-slate-100">Content</th>
                          <th className="p-3 font-bold border-b border-slate-100">Status</th>
                        </tr>
                      </thead>
                      <tbody className="text-xs font-medium">
                        {decontaminationQueue.map((item, i) => (
                          <tr key={i} className="border-b border-slate-50 hover:bg-slate-50 transition-colors">
                            <td className="p-3 font-bold text-indigo-600">{item.id}</td>
                            <td className="p-3 text-slate-600">{item.origin}</td>
                            <td className="p-3 text-slate-800">{item.content}</td>
                            <td className="p-3">
                              <span className={`px-2 py-1 rounded-md text-[10px] font-black uppercase ${item.status === 'Washing' ? 'bg-blue-100 text-blue-700' : 'bg-amber-100 text-amber-700'}`}>
                                {item.status}
                              </span>
                            </td>
                          </tr>
                        ))}
                      </tbody>
                    </table>
                  </div>
                </div>
              </div>
            </>
          )}

          {activeTab !== "dashboard" && (
            <div className="flex flex-col items-center justify-center h-full text-slate-400 space-y-4">
              <ShieldCheck className="w-16 h-16 opacity-20" />
              <h2 className="text-xl font-bold">{isAr ? "هذه الوحدة قيد التجهيز الفني" : "Module Section Under Construction"}</h2>
              <p className="text-sm font-medium">{isAr ? "جاري ربط الأجهزة الطبية" : "Integrating medical devices..."}</p>
            </div>
          )}

        </div>
      </div>
    </div>
  );
}
